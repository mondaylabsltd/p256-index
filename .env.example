# HTTP service port
PORT=11256

# Required durable infrastructure. Keep credentials out of version control.
P256_INDEX_IGGY_URL=iggy+tcp://user:replace-with-password@iggy.example:5100?reconnection_retries=5&reconnection_interval=1s&reestablish_after=5s&heartbeat_interval=3s&nodelay=true
P256_INDEX_REDIS_URL=redis://redis.example:6379/0

# Optional least-privilege connections. Both default to P256_INDEX_IGGY_URL.
# P256_INDEX_IGGY_CONSUMER_URL=iggy+tcp://consumer:password@iggy.example:5100
# P256_INDEX_IGGY_PROVISIONER_URL=iggy+tcp://provisioner:password@iggy.example:5100
P256_INDEX_IGGY_CONSUMER_GROUP=p256-index-server-v1
P256_INDEX_IGGY_ENQUEUE_TIMEOUT_SECS=5

# Required for the background chain writer. If unset, only read APIs run.
PRIVATE_KEY=0x...
QUEUE_WORKER=1

# Optional priority Gnosis write RPC.
ALCHEMY_API_KEY=

# Global accepted creates per minute. Per-IP limit remains 5/minute.
GLOBAL_WRITE_LIMIT=40

# Operator alerts (heartbeat, low-funding, stuck-nonce, DLQ). Without both set,
# alerts are logged instead of delivered.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional build tag surfaced in the daily heartbeat.
# RELEASE=

RUST_LOG=p256_index_server=info,tower_http=info
