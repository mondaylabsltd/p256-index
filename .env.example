# Service port
PORT=11256

# Queue database path
QUEUE_DB_PATH=queue.db

# Server wallet private key (for on-chain transactions).
# Must be a 0x-prefixed 32-byte (64 hex char) key; startup fails fast otherwise.
PRIVATE_KEY=0x...

# Optional priority write RPC (also honored by the CF Worker).
ALCHEMY_API_KEY=

# Background queue worker. Defaults ON. Set to 0 to run READ-ONLY (no on-chain
# signing) — the `dev` task sets this so a dev machine never becomes a live
# mainnet signer. Leave UNSET in production.
QUEUE_WORKER=1

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
